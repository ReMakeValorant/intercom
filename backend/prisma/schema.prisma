generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum RoomType {
  production
  technique
  externe
  prive
  help
  other
}

enum PermissionLevel {
  inherit
  none
  listen
  talk_ptt
  duplex
  admin
  move
  mute
  deafen
  whisper
}

enum AuditAction {
  create
  update
  delete
  login
  sync
  murmur_action
  preset_apply
}

model AdminUser {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]

  @@map("admin_users")
}

model User {
  id                  String                   @id @default(cuid())
  email               String?                  @unique
  displayName         String
  passwordHash        String?
  mumbleUserId        Int?
  primaryRoleId       String?
  portalEnabled       Boolean                  @default(true)
  isActive            Boolean                  @default(true)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  primaryRole         Role?                    @relation("PrimaryRole", fields: [primaryRoleId], references: [id], onDelete: SetNull)
  roles               UserRole[]
  overrides           UserPermissionOverride[]
  mumbleAccounts      MumbleAccount[]

  @@map("users")
}

model Role {
  id          String               @id @default(cuid())
  name        String               @unique
  slug        String               @unique
  color       String               @default("#60a5fa")
  sortOrder   Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  primaryUsers User[]              @relation("PrimaryRole")
  users       UserRole[]
  permissions RoleRoomPermission[]

  @@map("roles")
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Room {
  id              String                   @id @default(cuid())
  name            String
  slug            String                   @unique
  parentId        String?
  sortOrder       Int                      @default(0)
  type            RoomType                 @default(production)
  murmurChannelId Int?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  parent          Room?                    @relation("RoomTree", fields: [parentId], references: [id], onDelete: SetNull)
  children        Room[]                   @relation("RoomTree")
  rolePermissions RoleRoomPermission[]
  overrides       UserPermissionOverride[]

  @@map("rooms")
}

model Permission {
  id          String          @id @default(cuid())
  key         PermissionLevel @unique
  label       String
  description String?

  @@map("permissions")
}

model RoleRoomPermission {
  id         String          @id @default(cuid())
  roleId     String
  roomId     String
  permission PermissionLevel @default(inherit)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  role       Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  room       Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roleId, roomId])
  @@map("role_room_permissions")
}

model UserPermissionOverride {
  id         String          @id @default(cuid())
  userId     String
  roomId     String
  permission PermissionLevel @default(inherit)
  reason     String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  room       Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@map("user_permission_overrides")
}

model MumbleAccount {
  id             String   @id @default(cuid())
  userId         String
  mumbleUserId   Int      @unique
  username       String
  certificateHash String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mumble_accounts")
}

model AuditLog {
  id           String      @id @default(cuid())
  adminUserId  String?
  action       AuditAction
  entity       String
  entityId     String?
  oldValue     Json?
  newValue     Json?
  ipAddress    String?
  createdAt    DateTime    @default(now())
  adminUser    AdminUser?   @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Preset {
  id          String   @id @default(cuid())
  name        String
  description String?
  snapshot    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("presets")
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}
